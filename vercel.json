{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "github": {
    "silent": false
  },
  "buildCommand": "prisma migrate deploy && next build",
  "ignoreCommand": "git diff HEAD~1 --quiet -- src/ prisma/ public/ next.config.ts package.json vercel.json",
  "crons": [
    {
      "path": "/api/internal/civitai-lora/prewarm",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/internal/execution/sweep",
      "schedule": "0 12 * * *"
    }
  ]
}
