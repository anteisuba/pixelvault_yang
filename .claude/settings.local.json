          {
            "type": "command",
            "command": "node -e 'let d=\"\";process.stdin.on(\"data\",c=>d+=c);process.stdin.on(\"end\",()=>{const j=JSON.parse(d);const f=j.tool_input?.file_path||j.tool_response?.filePath||\"\";if(/\\.(ts|tsx)$/.test(f)){const{execSync}=require(\"child_process\");try{execSync(\"npx prettier --write \"+JSON.stringify(f),{stdio:\"pipe\"})}catch{}}})'",
            "timeout": 15,
            "statusMessage": "Formatting..."
          },
          {
            "type": "command",
            "command": "node -e 'let d=\"\";process.stdin.on(\"data\",c=>d+=c);process.stdin.on(\"end\",()=>{const j=JSON.parse(d);const f=j.tool_input?.file_path||j.tool_response?.filePath||\"\";if(/src[\\\\/]services[\\\\/]|prisma[\\\\/]/.test(f)){const{execSync}=require(\"child_process\");try{execSync(\"npx tsc --noEmit\",{encoding:\"utf8\",timeout:30000});process.stdout.write(JSON.stringify({hookSpecificOutput:{hookEventName:\"PostToolUse\",additionalContext:\"Type check passed.\"}}))}catch(e){process.stdout.write(JSON.stringify({hookSpecificOutput:{hookEventName:\"PostToolUse\",additionalContext:\"Type check errors:\\n\"+e.stdout}}))}}})'",
            "timeout": 45,
            "statusMessage": "Type checking..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e 'let d=\"\";process.stdin.on(\"data\",c=>d+=c);process.stdin.on(\"end\",()=>{const j=JSON.parse(d);const f=j.tool_input?.file_path||\"\";if(/[\\\\/]\\.env/.test(f)){process.stdout.write(JSON.stringify({decision:\"block\",reason:\"Blocked: do not edit .env files directly. Manage environment variables through your deployment platform or manually outside Claude Code.\"}))}})'",
            "timeout": 5,
            "statusMessage": "Checking file safety..."
          }
        ]
      }
    ]
