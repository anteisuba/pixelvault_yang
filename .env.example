# ──────────────────────────────────────────────────────────────────────────
# PixelVault — environment template
#
# Copy to .env.local and fill in. NEVER commit .env.local (it is gitignored).
# Everything here is a placeholder — no real secrets.
#
# ⚠️  TEST-ONLY vs PRODUCTION
# Credentials you put in .env.local for local dev / testing (the E2E test user,
# any provider keys used to exercise the app) must be THROWAWAY / DEV-instance /
# spend-capped. NEVER reuse production API keys or production credentials for
# testing, and never let a test key reach production.
#
# API KEYS — TWO LAYERS (this answers "do API keys go in env?"):
#   1. SYSTEM / PLATFORM keys = the AI provider vars below. Fallback used for
#      free-tier generations + model health checks. PUT THESE IN .env.local to
#      make generation work locally without per-user setup. (Use test keys.)
#   2. USER keys (bring-your-own) = entered in-app via QuickSetupDialog,
#      encrypted with API_KEY_ENCRYPTION_SECRET, stored per-user in the DB.
#      NOT set via env. To test the BYO flow, configure a key in the app for
#      your signed-in (test) user; for E2E, seed it through the api-keys API.
# ──────────────────────────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
NEXT_PUBLIC_APP_URL=http://localhost:3000
BASE_URL=http://localhost:3000

# ── Auth (Clerk) — use a DEVELOPMENT instance locally (pk_test_/sk_test_) ───
# Required. The @clerk/testing visual-regression setup also needs these.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# ── Storage (Cloudflare R2) ─────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
NEXT_PUBLIC_STORAGE_BASE_URL=https://cdn.example.com

# ── Secrets for encrypting user-stored keys/tokens (required for BYO flow) ──
# 32-byte hex: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY_ENCRYPTION_SECRET=
CIVITAI_TOKEN_SECRET=

# ── AI provider SYSTEM keys (layer 1 above — optional fallback; TEST keys) ──
HF_API_TOKEN=
GEMINI_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
FAL_API_KEY=            # platform-keys reads this; the fal SDK also reads FAL_KEY
REPLICATE_API_TOKEN=
NOVELAI_API_TOKEN=
VOLCENGINE_API_KEY=
RUNWAYML_API_SECRET=    # alt: RUNWAY_API_KEY
CIVITAI_API_TOKEN=
FISH_AUDIO_VOICE_LIBRARY_API_KEY=
AI_GATEWAY_API_KEY=

# ── Infra (optional for local dev) ──────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
EXECUTION_WORKER_BASE_URL=
INTERNAL_CALLBACK_SECRET=
CRON_SECRET=
HEALTH_CHECK_TOKEN=
ADMIN_USER_IDS=         # comma-separated Clerk user IDs
VERCEL_PROTECTION_BYPASS=

# ── Observability ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
LOG_LEVEL=info

# ── Feature flags (NEXT_PUBLIC_FF_*) — "true"/"false", *_ROLLOUT = 0-100 ────
NEXT_PUBLIC_FF_IMAGE_EDITING=false
NEXT_PUBLIC_FF_MULTI_COMPARE=false
NEXT_PUBLIC_FF_SERIES_MODE=false
NEXT_PUBLIC_FF_SMART_PROMPT=false
NEXT_PUBLIC_FF_SMART_PROMPT_ROLLOUT=0
NEXT_PUBLIC_FF_VARIANT_GEN=false
NEXT_PUBLIC_FF_VARIANT_GEN_ROLLOUT=0
NEXT_PUBLIC_ENABLE_VERCEL_TOOLBAR=false

# ── E2E / visual regression (Playwright) ────────────────────────────────────
# ⚠️ TEST-ONLY: dedicated Clerk DEVELOPMENT-instance test user (email+password).
# Never a real/production account. Used by e2e/auth.setup.ts to save an
# authenticated storageState for studio visual specs.
E2E_CLERK_USER_EMAIL=
E2E_CLERK_USER_PASSWORD=
