{
  "name": "personal-ai-gallery",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "check:node": "node ./scripts/check-node-version.cjs",
    "predev": "npm run check:node",
    "dev": "next dev",
    "prebuild": "npm run check:node",
    "build": "next build",
    "prisma:generate": "prisma generate",
    "prestart": "npm run check:node",
    "start": "next start",
    "prelint": "npm run check:node",
    "lint": "eslint src",
    "pretest": "npm run check:node",
    "test": "vitest",
    "pretest:run": "npm run check:node",
    "test:run": "vitest run",
    "models:check-docs": "node ./scripts/check-model-docs.mjs --compare-snapshot docs/reference/api/model-doc-monitor.snapshot.json --report-json artifacts/model-doc-monitor/report.json --report-md artifacts/model-doc-monitor/report.md --write-current-snapshot artifacts/model-doc-monitor/current.snapshot.json",
    "models:update-doc-snapshot": "node ./scripts/check-model-docs.mjs --write-snapshot docs/reference/api/model-doc-monitor.snapshot.json --report-json artifacts/model-doc-monitor/report.json --report-md artifacts/model-doc-monitor/report.md",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css}\"",
    "analyze": "ANALYZE=true npm run build",
    "db:seed": "npx tsx --tsconfig tsconfig.json prisma/seed.ts",
    "prepare": "husky"
  },
  "engines": {
    "node": "22.x",
    "npm": ">=10"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "prisma": {
    "seed": "npx tsx --tsconfig tsconfig.json prisma/seed.ts"
  },
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "^1.7.10",
    "@aws-sdk/client-s3": "^3.993.0",
    "@aws-sdk/lib-storage": "^3.1015.0",
    "@clerk/localizations": "^4.6.4",
    "@clerk/nextjs": "^6.39.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/model-viewer": "^4.2.0",
    "@gradio/client": "^2.1.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "7.7.0",
    "@radix-ui/react-toolbar": "^1.1.11",
    "@sentry/nextjs": "^10.46.0",
    "@types/dagre": "^0.7.54",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@xyflow/react": "^12.10.2",
    "ai": "^6.0.191",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dagre": "^0.8.5",
    "framer-motion": "^12.40.0",
    "html2canvas": "^1.4.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.574.0",
    "marked": "^18.0.0",
    "motion": "^12.38.0",
    "next": "16.2.6",
    "next-intl": "^4.9.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "react-textarea-autosize": "^8.5.9",
    "react-zoom-pan-pinch": "^4.0.2",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "shiki": "^4.0.2",
    "sonner": "^2.0.7",
    "svix": "^1.85.0",
    "tailwind-merge": "^3.5.0",
    "three": "0.182.0",
    "vaul": "^1.1.2",
    "yet-another-react-lightbox": "^3.30.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.6",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "dotenv": "^17.3.1",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prisma": "7.7.0",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "postcss": "8.5.14"
  }
}
