{
  "name": "personal-ai-gallery",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "check:node": "node ./scripts/check-node-version.cjs",
    "predev": "npm run check:node",
    "dev": "next dev",
    "prebuild": "npm run check:node",
    "build": "prisma generate && next build",
    "prestart": "npm run check:node",
    "start": "next start",
    "prelint": "npm run check:node",
    "lint": "eslint",
    "pretest": "npm run check:node",
    "test": "vitest",
    "pretest:run": "npm run check:node",
    "test:run": "vitest run",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css}\"",
    "analyze": "ANALYZE=true npm run build",
    "db:seed": "npx tsx --tsconfig tsconfig.json prisma/seed.ts",
    "prepare": "husky"
  },
  "engines": {
    "node": "22.x",
    "npm": ">=10"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "prisma": {
    "seed": "npx tsx --tsconfig tsconfig.json prisma/seed.ts"
  },
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "^1.7.10",
    "@aws-sdk/client-s3": "^3.993.0",
    "@aws-sdk/lib-storage": "^3.1015.0",
    "@aws-sdk/s3-request-presigner": "^3.1029.0",
    "@clerk/localizations": "^4.2.1",
    "@clerk/nextjs": "^6.38.0",
    "@formkit/auto-animate": "^0.9.0",
    "@gradio/client": "^2.1.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-toolbar": "^1.1.11",
    "@sentry/nextjs": "^10.46.0",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@tanstack/react-virtual": "^3.13.23",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "html2canvas": "^1.4.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.574.0",
    "marked": "^18.0.0",
    "motion": "^12.38.0",
    "next": "16.1.6",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "openai": "^6.22.0",
    "pg": "^8.18.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "react-photo-album": "^3.5.1",
    "react-resizable-panels": "^4.9.0",
    "react-zoom-pan-pinch": "^4.0.2",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "shiki": "^4.0.2",
    "sonner": "^2.0.7",
    "svix": "^1.85.0",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2",
    "yet-another-react-lightbox": "^3.30.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.2",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sharp": "^0.32.0",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prisma": "^7.4.0",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
