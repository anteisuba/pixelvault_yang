generator client {
  provider = "prisma-client"
  output   = "../src/lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────

enum OutputType {
  IMAGE
  VIDEO
  AUDIO
}

enum GenerationStatus {
  PENDING
  COMPLETED
  FAILED
}

enum GenerationJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum ExecutionOutboxStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum CharacterCardStatus {
  DRAFT
  REFINING
  STABLE
  ARCHIVED
}

enum LoraTrainingStatus {
  QUEUED
  TRAINING
  COMPLETED
  FAILED
  CANCELED
}

enum VideoPipelineStatus {
  RUNNING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

enum PipelineClipStatus {
  PENDING
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum VideoScriptStatus {
  DRAFT
  SCRIPT_READY
  FRAMES_READY
  CLIPS_READY
  COMPLETED
  FAILED
}

enum VideoScriptSceneStatus {
  PENDING
  FRAME_GENERATING
  FRAME_READY
  CLIP_GENERATING
  CLIP_READY
  FAILED
}

// ─── Models ───────────────────────────────────────────────────────

model User {
  id               String   @id @default(uuid())
  clerkId          String   @unique
  email            String   @unique
  username         String?  @unique
  displayName      String?
  avatarUrl        String?
  avatarStorageKey String?
  bannerUrl        String?
  bannerStorageKey String?
  bio              String?  @db.Text
  civitaiToken     String? // AES-256-GCM encrypted Civitai API token
  isPublic         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  generations      Generation[]
  userApiKeys      UserApiKey[]
  generationJobs   GenerationJob[]
  apiUsageLedger   ApiUsageLedger[]
  imageAnalyses    ImageAnalysis[]
  arenaMatches     ArenaMatch[]
  stories          Story[]
  projects         Project[]
  characterCards   CharacterCard[]
  likesGiven       UserLike[]        @relation("LikesGiven")
  followsGiven     UserFollow[]      @relation("FollowsGiven")
  followsReceived  UserFollow[]      @relation("FollowsReceived")
  collections      Collection[]
  backgroundCards  BackgroundCard[]
  styleCards       StyleCard[]
  cardRecipes      CardRecipe[]
  videoPipelines   VideoPipeline[]
  loraTrainingJobs LoraTrainingJob[]
  videoScripts     VideoScript[]

  @@index([username])
}

model Project {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?  @db.Text
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  generations     Generation[]
  characterCards  CharacterCard[]
  backgroundCards BackgroundCard[]
  styleCards      StyleCard[]
  cardRecipes     CardRecipe[]

  @@index([userId, isDeleted, updatedAt(sort: Desc)])
}

model UserApiKey {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  modelId        String
  adapterType    String
  providerConfig Json
  label          String
  encryptedKey   String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, adapterType, modelId])
  @@index([userId, modelId, adapterType])
}

model Generation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  // ── 輸出媒體 ──────────────────────────────────────────────────
  outputType OutputType       @default(IMAGE)
  status     GenerationStatus @default(COMPLETED)
  url        String // R2 永久 URL
  storageKey String // R2 bucket 內的文件路徑
  mimeType   String           @default("image/png")

  // 圖片 / 影格尺寸
  width  Int @default(1024)
  height Int @default(1024)

  // 視頻專用（圖片留 null）
  duration Float? // 秒數，例如 5.0

  // ── 參考圖片 ────────────────────────────────────────────────────
  referenceImageUrl String? // R2 永久 URL（用戶上傳的參考圖）

  // ── Prompt ────────────────────────────────────────────────────
  prompt         String  @db.Text
  negativePrompt String? @db.Text

  // ── 模型資訊 ──────────────────────────────────────────────────
  model    String // 對應 AI_MODELS enum 的值
  provider String // "HuggingFace" | "SiliconFlow" | "Seedance" 等

  // ── API usage ────────────────────────────────────────────────
  requestCount     Int     @default(1)
  isFreeGeneration Boolean @default(false)

  // ── 可見性 ────────────────────────────────────────────────────
  isPublic       Boolean @default(false)
  isPromptPublic Boolean @default(false)
  isFeatured     Boolean @default(false)

  // ── 關聯 ──────────────────────────────────────────────────────
  userId          String?
  user            User?                     @relation(fields: [userId], references: [id])
  projectId       String?
  project         Project?                  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  characterCardId String?
  characterCard   CharacterCard?            @relation(fields: [characterCardId], references: [id], onDelete: SetNull)
  characterCards  GenerationCharacterCard[]
  cardRecipeId    String?
  cardRecipe      CardRecipe?               @relation(fields: [cardRecipeId], references: [id], onDelete: SetNull)
  recipeSnapshot  Json?

  // ── B0: Generation Snapshot ────────────────────────────────────
  snapshot      Json? // Full input parameter snapshot
  runGroupId    String? // Groups compare/variant runs
  runGroupType  String  @default("single") // "single" | "compare" | "variant"
  runGroupIndex Int     @default(0) // Position within group (0-based)
  isWinner      Boolean @default(false) // Winner flag for compare mode
  seed          BigInt? // Seed for reproducibility

  generationJob   GenerationJob?   @relation("GenerationToJob")
  apiUsageLedger  ApiUsageLedger[] @relation("GenerationToUsage")
  arenaEntries    ArenaEntry[]
  storyPanels     StoryPanel[]
  likes           UserLike[]
  collectionItems CollectionItem[]
  videoPipeline   VideoPipeline?

  @@index([userId])
  @@index([userId, isFeatured, isPublic, createdAt(sort: Desc)])
  @@index([userId, isFreeGeneration, createdAt(sort: Desc)])
  @@index([outputType, isPublic, createdAt(sort: Desc)])
  @@index([userId, isPublic, createdAt(sort: Desc)])
  @@index([projectId, createdAt(sort: Desc)])
  @@index([characterCardId, createdAt(sort: Desc)])
  @@index([runGroupId])
}

model GenerationJob {
  id                String              @id @default(uuid())
  userId            String
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  generationId      String?             @unique
  generation        Generation?         @relation("GenerationToJob", fields: [generationId], references: [id], onDelete: SetNull)
  adapterType       String
  provider          String
  modelId           String
  status            GenerationJobStatus @default(QUEUED)
  requestCount      Int                 @default(0)
  prompt            String?             @db.Text
  errorMessage      String?             @db.Text
  externalRequestId String?
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  apiUsageLedger  ApiUsageLedger[] @relation("GenerationJobToUsage")
  executionOutbox ExecutionOutbox?

  @@index([userId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}

model ExecutionOutbox {
  id              String               @id @default(uuid())
  generationJobId String               @unique
  generationJob   GenerationJob        @relation(fields: [generationJobId], references: [id], onDelete: Cascade)
  kind            String
  status          ExecutionOutboxStatus @default(PENDING)
  payload         Json
  result          Json?
  attemptCount    Int                  @default(0)
  lastError       String?              @db.Text
  leaseExpiresAt  DateTime?
  processedAt     DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([status, leaseExpiresAt, createdAt(sort: Desc)])
}

model ApiUsageLedger {
  id               String         @id @default(uuid())
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  generationId     String?
  generation       Generation?    @relation("GenerationToUsage", fields: [generationId], references: [id], onDelete: SetNull)
  generationJobId  String?
  generationJob    GenerationJob? @relation("GenerationJobToUsage", fields: [generationJobId], references: [id], onDelete: SetNull)
  adapterType      String
  provider         String
  modelId          String
  requestCount     Int            @default(1)
  inputImageCount  Int            @default(0)
  outputImageCount Int            @default(1)
  width            Int?
  height           Int?
  durationMs       Int?
  wasSuccessful    Boolean        @default(true)
  errorMessage     String?        @db.Text
  createdAt        DateTime       @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([adapterType, modelId, createdAt(sort: Desc)])
  @@index([wasSuccessful, createdAt(sort: Desc)])
}

model ImageAnalysis {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceImageUrl   String
  sourceStorageKey String
  generatedPrompt  String   @db.Text
  modelUsed        String
  createdAt        DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

model ArenaMatch {
  id             String       @id @default(uuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompt         String       @db.Text
  aspectRatio    String
  referenceImage String?      @db.Text
  winnerId       String?
  votedAt        DateTime?
  createdAt      DateTime     @default(now())
  entries        ArenaEntry[]

  @@index([userId, createdAt(sort: Desc)])
}

model ArenaEntry {
  id           String     @id @default(uuid())
  matchId      String
  match        ArenaMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  generationId String
  generation   Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)
  modelId      String
  slotIndex    Int
  wasVoted     Boolean    @default(false)

  @@unique([matchId, generationId])
}

model ModelEloRating {
  id          String   @id @default(uuid())
  modelId     String   @unique
  modelFamily String?
  rating      Float    @default(1500)
  matchCount  Int      @default(0)
  winCount    Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@index([modelFamily, rating(sort: Desc)])
}

model ModelConfig {
  id              String     @id @default(uuid())
  modelId         String     @unique
  externalModelId String
  adapterType     String
  outputType      OutputType @default(IMAGE)
  cost            Int        @default(1)
  available       Boolean    @default(true)
  officialUrl     String?
  timeoutMs       Int?
  qualityTier     String?
  i2vModelId      String?
  videoDefaults   Json?
  providerConfig  Json
  sortOrder       Int        @default(0)
  healthStatus    String?
  lastHealthCheck DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([outputType, available, sortOrder])
}

model Story {
  id           String       @id @default(uuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String
  coverImageId String?
  displayMode  String       @default("scroll")
  isPublic     Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  panels       StoryPanel[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([isPublic, createdAt(sort: Desc)])
  @@index([userId, isPublic, createdAt(sort: Desc)])
}

model StoryPanel {
  id           String      @id @default(uuid())
  storyId      String
  story        Story       @relation(fields: [storyId], references: [id], onDelete: Cascade)
  generationId String?
  generation   Generation? @relation(fields: [generationId], references: [id], onDelete: SetNull)
  orderIndex   Int
  caption      String?     @db.Text
  narration    String?     @db.Text
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([storyId, orderIndex])
  @@index([storyId, orderIndex])
}

model CharacterCard {
  id                 String              @id @default(uuid())
  userId             String
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId          String?
  project            Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  name               String
  description        String?             @db.Text
  sourceImageUrl     String // Primary source image URL (first uploaded)
  sourceStorageKey   String
  sourceImages       Json? // string[] — all uploaded source image URLs (legacy flat)
  sourceImageEntries Json? // SourceImageEntry[] — structured with viewType
  characterPrompt    String              @db.Text
  modelPrompts       Json? // Record<adapterType, optimizedPrompt>
  referenceImages    Json? // string[] — best generation R2 URLs
  attributes         Json? // CharacterAttributes structured data
  loras              Json? // Lora[] — character-specific LoRA models [{url, scale}]
  tags               String[]            @default([])
  status             CharacterCardStatus @default(DRAFT)
  stabilityScore     Float?
  isDeleted          Boolean             @default(false)

  // ── Variant system (folder-like) ────────────────────────────
  parentId     String? // null = root card, set = variant of parent
  parent       CharacterCard?  @relation("CharacterCardVariants", fields: [parentId], references: [id], onDelete: Cascade)
  variants     CharacterCard[] @relation("CharacterCardVariants")
  variantLabel String? // e.g. "Anime Style", "3D Model", "Chibi"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  generations      Generation[]
  generationLinks  GenerationCharacterCard[]
  recipesAsChar    CardRecipe[]              @relation("RecipeCharacter")
  loraTrainingJobs LoraTrainingJob[]

  @@index([userId, isDeleted, updatedAt(sort: Desc)])
  @@index([userId, status, isDeleted])
  @@index([parentId, isDeleted, updatedAt(sort: Desc)])
  @@index([userId, projectId, isDeleted, updatedAt(sort: Desc)])
}

model GenerationCharacterCard {
  id              String        @id @default(uuid())
  generationId    String
  generation      Generation    @relation(fields: [generationId], references: [id], onDelete: Cascade)
  characterCardId String
  characterCard   CharacterCard @relation(fields: [characterCardId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@unique([generationId, characterCardId])
  @@index([characterCardId, createdAt(sort: Desc)])
  @@index([generationId])
}

model UserLike {
  id           String     @id @default(uuid())
  userId       String
  user         User       @relation("LikesGiven", fields: [userId], references: [id], onDelete: Cascade)
  generationId String
  generation   Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([userId, generationId])
  @@index([generationId])
  @@index([userId, createdAt(sort: Desc)])
}

model UserFollow {
  id          String   @id @default(uuid())
  followerId  String
  follower    User     @relation("FollowsGiven", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("FollowsReceived", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followingId])
  @@index([followerId, createdAt(sort: Desc)])
}

model Collection {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?  @db.Text
  coverUrl    String?
  isPublic    Boolean  @default(false)
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items CollectionItem[]

  @@index([userId, isDeleted, updatedAt(sort: Desc)])
  @@index([isPublic, isDeleted, updatedAt(sort: Desc)])
}

model CollectionItem {
  id           String     @id @default(uuid())
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  generationId String
  generation   Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)
  orderIndex   Int        @default(0)
  addedAt      DateTime   @default(now())

  @@unique([collectionId, generationId])
  @@index([collectionId, orderIndex])
  @@index([generationId])
}

// ─── Composable Card System ─────────────────────────────────────

model BackgroundCard {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId        String?
  project          Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  name             String
  description      String?  @db.Text
  sourceImageUrl   String?
  sourceStorageKey String?
  backgroundPrompt String   @db.Text
  attributes       Json?
  loras            Json? // Lora[] — background-specific LoRA models
  tags             String[] @default([])
  isDeleted        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  recipesAsBg CardRecipe[] @relation("RecipeBackground")

  @@index([userId, projectId, isDeleted, updatedAt(sort: Desc)])
}

model StyleCard {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId        String?
  project          Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  name             String
  description      String?  @db.Text
  sourceImageUrl   String?
  sourceStorageKey String?
  stylePrompt      String   @db.Text
  attributes       Json?
  loras            Json? // Lora[] — style-specific LoRA models
  modelId          String? // AI_MODELS enum value (replaces ModelCard)
  adapterType      String? // AI_ADAPTER_TYPES value
  advancedParams   Json? // AdvancedParams (guidance, steps, seed, loras)
  tags             String[] @default([])
  isDeleted        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  recipesAsStyle CardRecipe[] @relation("RecipeStyle")

  @@index([userId, projectId, isDeleted, updatedAt(sort: Desc)])
}

model CardRecipe {
  id               String          @id @default(uuid())
  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId        String?
  project          Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  name             String
  characterCardId  String?
  characterCard    CharacterCard?  @relation("RecipeCharacter", fields: [characterCardId], references: [id], onDelete: SetNull)
  backgroundCardId String?
  backgroundCard   BackgroundCard? @relation("RecipeBackground", fields: [backgroundCardId], references: [id], onDelete: SetNull)
  styleCardId      String?
  styleCard        StyleCard?      @relation("RecipeStyle", fields: [styleCardId], references: [id], onDelete: SetNull)
  freePrompt       String?         @db.Text
  isDeleted        Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  generations Generation[]

  @@index([userId, projectId, isDeleted, updatedAt(sort: Desc)])
}

// ─── Long Video Pipeline ────────────────────────────────────────

model VideoPipeline {
  id     String              @id @default(uuid())
  userId String
  user   User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  status VideoPipelineStatus @default(RUNNING)

  // Generation parameters (frozen at pipeline creation)
  prompt         String  @db.Text
  modelId        String
  adapterType    String
  aspectRatio    String  @default("16:9")
  resolution     String?
  negativePrompt String? @db.Text

  // Extension method: "native_extend" | "last_frame_chain"
  extensionMethod String @default("native_extend")

  // Target & progress
  targetDurationSec  Int
  currentDurationSec Float @default(0)
  totalClips         Int   @default(1)
  completedClips     Int   @default(0)

  // Final output
  finalVideoUrl   String?
  finalStorageKey String?
  generationId    String?     @unique
  generation      Generation? @relation(fields: [generationId], references: [id], onDelete: SetNull)

  // Reference for character consistency
  characterCardIds  String[] @default([])
  referenceImageUrl String?
  apiKeyId          String?

  errorMessage String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clips VideoPipelineClip[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}

model VideoPipelineClip {
  id         String             @id @default(uuid())
  pipelineId String
  pipeline   VideoPipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  clipIndex  Int
  status     PipelineClipStatus @default(PENDING)

  // Job tracking
  generationJobId   String?
  externalRequestId String? @db.Text

  // Clip result
  videoUrl     String?
  storageKey   String?
  lastFrameUrl String?
  durationSec  Float?

  // Extension input
  inputVideoUrl String? // For native extend: previous clip's video URL
  inputFrameUrl String? // For last-frame chain: previous clip's last frame

  errorMessage String?   @db.Text
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([pipelineId, clipIndex])
  @@index([pipelineId, clipIndex])
  @@index([status, createdAt(sort: Desc)])
}

// ─── LoRA Training ────────────────────────────────────────────────

model LoraTrainingJob {
  id                 String             @id @default(uuid())
  userId             String
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  name               String
  triggerWord        String
  loraType           String             @default("subject") // "subject" | "style"
  baseModel          String             @default("flux-dev")
  trainingImageKeys  String[] // R2 storage keys
  status             LoraTrainingStatus @default(QUEUED)
  externalTrainingId String? // Replicate training ID
  progress           Float              @default(0) // 0-1
  errorMessage       String?            @db.Text
  loraUrl            String? // Trained LoRA URL
  loraStorageKey     String? // R2 backup key
  createdAt          DateTime           @default(now())
  startedAt          DateTime?
  completedAt        DateTime?

  characterCardId String?
  characterCard   CharacterCard? @relation(fields: [characterCardId], references: [id], onDelete: SetNull)

  @@index([userId, status, createdAt(sort: Desc)])
}

// ─── Video Script (VS1-VS11) ──────────────────────────────────────

model VideoScript {
  id              String             @id @default(cuid())
  userId          String
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic           String             @db.Text
  targetDuration  Int // 30 | 60 | 120 (seconds)
  totalScenes     Int // derived from targetDuration
  status          VideoScriptStatus  @default(DRAFT)
  consistencyMode String // 'character_card' | 'first_frame_ref'
  characterCardId String? // required when consistencyMode = 'character_card'
  styleCardId     String? // optional global style
  videoModelId    String // 'seedance-2-fast' | 'kling-pro'
  finalVideoUrl   String?
  scenes          VideoScriptScene[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, status, createdAt(sort: Desc)])
}

model VideoScriptScene {
  id                String                 @id @default(cuid())
  scriptId          String
  script            VideoScript            @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  orderIndex        Int
  duration          Int
  cameraShot        String
  action            String                 @db.Text
  dialogue          String?                @db.Text
  transition        String // 'cut' | 'fade' | 'dissolve' (Phase 1 only 'cut')
  frameGenerationId String? // VS10: plain string, no FK
  clipGenerationId  String? // VS10: plain string, no FK
  status            VideoScriptSceneStatus @default(PENDING)
  errorMessage      String?                @db.Text
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@unique([scriptId, orderIndex])
  @@index([scriptId, orderIndex])
  @@index([status, createdAt(sort: Desc)])
}
