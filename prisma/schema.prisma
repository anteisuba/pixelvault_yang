generator client {
  provider = "prisma-client"
  output   = "../src/lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────

enum OutputType {
  IMAGE
  VIDEO
  AUDIO
}

enum GenerationStatus {
  PENDING
  COMPLETED
  FAILED
}

enum GenerationJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

// ─── Models ───────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  clerkId   String   @unique
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  generations    Generation[]
  userApiKeys    UserApiKey[]
  generationJobs GenerationJob[]
  apiUsageLedger ApiUsageLedger[]
  imageAnalyses  ImageAnalysis[]
}

model UserApiKey {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  modelId        String
  adapterType    String
  providerConfig Json
  label          String
  encryptedKey   String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId, modelId, adapterType])
}

model Generation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  // ── 輸出媒體 ──────────────────────────────────────────────────
  outputType OutputType       @default(IMAGE)
  status     GenerationStatus @default(COMPLETED)
  url        String // R2 永久 URL
  storageKey String // R2 bucket 內的文件路徑
  mimeType   String           @default("image/png")

  // 圖片 / 影格尺寸
  width  Int @default(1024)
  height Int @default(1024)

  // 視頻專用（圖片留 null）
  duration Float? // 秒數，例如 5.0

  // ── Prompt ────────────────────────────────────────────────────
  prompt         String  @db.Text
  negativePrompt String? @db.Text

  // ── 模型資訊 ──────────────────────────────────────────────────
  model    String // 對應 AI_MODELS enum 的值
  provider String // "HuggingFace" | "SiliconFlow" | "Seedance" 等

  // ── API usage ────────────────────────────────────────────────
  requestCount Int @default(1)

  // ── 可見性 ────────────────────────────────────────────────────
  isPublic Boolean @default(true)

  // ── 關聯 ──────────────────────────────────────────────────────
  userId         String?
  user           User?            @relation(fields: [userId], references: [id])
  generationJob  GenerationJob?   @relation("GenerationToJob")
  apiUsageLedger ApiUsageLedger[] @relation("GenerationToUsage")

  @@index([userId])
  @@index([outputType, isPublic, createdAt(sort: Desc)])
}

model GenerationJob {
  id           String              @id @default(uuid())
  userId       String
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  generationId String?             @unique
  generation   Generation?         @relation("GenerationToJob", fields: [generationId], references: [id], onDelete: SetNull)
  adapterType  String
  provider     String
  modelId      String
  status       GenerationJobStatus @default(QUEUED)
  requestCount Int                 @default(0)
  errorMessage String?             @db.Text
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  apiUsageLedger ApiUsageLedger[] @relation("GenerationJobToUsage")

  @@index([userId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}

model ApiUsageLedger {
  id               String         @id @default(uuid())
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  generationId     String?
  generation       Generation?    @relation("GenerationToUsage", fields: [generationId], references: [id], onDelete: SetNull)
  generationJobId  String?
  generationJob    GenerationJob? @relation("GenerationJobToUsage", fields: [generationJobId], references: [id], onDelete: SetNull)
  adapterType      String
  provider         String
  modelId          String
  requestCount     Int            @default(1)
  inputImageCount  Int            @default(0)
  outputImageCount Int            @default(1)
  width            Int?
  height           Int?
  durationMs       Int?
  wasSuccessful    Boolean        @default(true)
  errorMessage     String?        @db.Text
  createdAt        DateTime       @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([adapterType, modelId, createdAt(sort: Desc)])
  @@index([wasSuccessful, createdAt(sort: Desc)])
}

model ImageAnalysis {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceImageUrl   String
  sourceStorageKey String
  generatedPrompt  String   @db.Text
  modelUsed        String
  createdAt        DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
}
